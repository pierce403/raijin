{
  "name": "raijin-sh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "dev": "concurrently -k \"npm:build:watch\" \"npm:dev:worker\"",
    "dev:worker": "wrangler dev --local --port 8787",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "vite": "^7.1.0",
    "wrangler": "^4.59.0"
  }
}
